# PostgreSQL (obligatorio en Vercel). En local: Neon gratis, Supabase o Postgres en Docker.
# Ejemplo Neon: postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Nombre visible del sitio (opcional)
NEXT_PUBLIC_SITE_NAME="Mary Mirari"

# URL pública de la tienda en Vercel (recomendado en producción)
NEXT_PUBLIC_SITE_URL="https://tu-proyecto.vercel.app"

# Texto personalizado de contacto en el mail al cliente (opcional)
# ORDER_EMAIL_CONTACT_NOTE="Te escribimos en las próximas 24 hs."

# Correo del remitente (obligatorio para enviar)
EMAIL_FROM="Mary Mirari <onboarding@resend.dev>"

# Correo donde recibís los pedidos (con onboarding@resend.dev = mismo mail que la cuenta Resend)
OWNER_EMAIL="tu-email@ejemplo.com"

# Resend (https://resend.com)
RESEND_API_KEY=""

# SMTP (solo si NO usás Resend)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
