# Base de datos (SQLite local: archivo en carpeta prisma/)
DATABASE_URL="file:./dev.db"

# Nombre visible del sitio (opcional)
NEXT_PUBLIC_SITE_NAME="Mary Mirari"

# URL pública (opcional: enlace al final del mail al cliente)
NEXT_PUBLIC_SITE_URL="https://tu-dominio.com"

# Texto personalizado de contacto en el mail al cliente (opcional; si vacío, usa mensaje por defecto con WhatsApp)
# ORDER_EMAIL_CONTACT_NOTE="Te escribimos en las próximas 24 hs."

# Correo del remitente (obligatorio para enviar)
EMAIL_FROM="Mary Mirari <onboarding@resend.dev>"

# Correo donde recibís los pedidos nuevos (con onboarding@resend.dev debe ser el MISMO
# correo con el que te registraste en Resend, o el mail al cliente falla con 403).
OWNER_EMAIL="tu-email@ejemplo.com"

# Opción A — Resend (https://resend.com): si está definida, se usa Resend
RESEND_API_KEY=""

# Opción B — SMTP (solo si NO usás Resend): Gmail, tu hosting, etc.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
