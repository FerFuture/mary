{
  "name": "mary_mirari",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev -H 127.0.0.1",
    "build": "node scripts/prisma-generate.cjs && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/prisma-generate.cjs",
    "db:push": "dotenv -e .env -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env -e .env.local -- prisma db seed",
    "db:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "db:upsert-products": "dotenv -e .env -e .env.local -- tsx prisma/upsert-products.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "^15.3.3",
    "nodemailer": "^8.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.4.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
